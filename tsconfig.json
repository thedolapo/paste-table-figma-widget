{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "lib": ["ES2020", "DOM"],
    "jsx": "react",
    "jsxFactory": "figma.widget.h",
    "jsxFragmentFactory": "figma.widget.Fragment",
    "outDir": "dist",
    "rootDir": ".",
    "typeRoots": ["./node_modules/@types", "./node_modules/@figma"],
    "skipLibCheck": true,
    "noEmit": false
  },
  "include": ["widget-src/**/*.ts", "widget-src/**/*.tsx", "src/**/*.ts"]
}
